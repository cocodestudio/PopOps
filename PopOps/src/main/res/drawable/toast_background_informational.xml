<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base white background with all rounded corners -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/popops_md_theme_surface"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- Blue color bar at left - only left corners rounded -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/popops_md_theme_primary"/>
            <corners
                android:topLeftRadius="12dp"
                android:topRightRadius="15dp"
                android:bottomLeftRadius="12dp"
                android:bottomRightRadius="15dp"/>
        </shape>
    </item>

    <!-- White content area that covers everything except 5dp bar -->
    <item android:left="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/popops_md_theme_surface"/>
            <corners
                android:bottomLeftRadius="15dp"
                android:bottomRightRadius="15dp"
                android:topLeftRadius="15dp"
                android:topRightRadius="15dp"/>
        </shape>
    </item>
</layer-list>